# Interface definition for thorn DGCoordinatesX

IMPLEMENTS: DGCoordinatesX

INCLUDES HEADER: dg.hxx IN dg.hxx

USES INCLUDE HEADER: dg.hxx

USES INCLUDE HEADER: div.hxx
USES INCLUDE HEADER: loop.hxx
USES INCLUDE HEADER: vect.hxx

PUBLIC:

CCTK_REAL coords TYPE=gf CENTERING={ccc} TAGS='checkpoint="no"' { coordx coordy coordz } "Coordinates"
CCTK_REAL volume TYPE=gf CENTERING={ccc} TAGS='checkpoint="no"' { cvol } "Cell volume"
